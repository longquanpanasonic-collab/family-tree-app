x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# NuGet
*.nupkg
*.snupkg

# Entity Framework
*.edmx.diagram

# SQL Server files
*.mdf
*.ldf

# Rider
.idea/
*.sln.iml

# App_Data
App_Data/

# Upload folder
Content/uploads/
